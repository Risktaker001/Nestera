# Public Sentry client configuration. Leave NEXT_PUBLIC_SENTRY_DSN empty for local/test runs.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
NEXT_PUBLIC_SENTRY_RELEASE=
NEXT_PUBLIC_SENTRY_DASHBOARD_URL=
NEXT_PUBLIC_SENTRY_ORG=
NEXT_PUBLIC_SENTRY_PROJECT=
NEXT_PUBLIC_SLOW_ROUTE_THRESHOLD_MS=3000
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.05
NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0
NEXT_PUBLIC_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1

# Server-side Sentry source map upload configuration. SENTRY_AUTH_TOKEN is secret and must never be exposed client-side.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.05
NEXT_PUBLIC_BASE_URL=https://nestera.app
NEXT_PUBLIC_HORIZON_PUBLIC_URL=https://horizon.stellar.org
NEXT_PUBLIC_HORIZON_TESTNET_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_COINGECKO_API_URL=https://api.coingecko.com/api/v3
NEXT_PUBLIC_DISCORD_URL=https://discord.gg/nestera
NEXT_PUBLIC_TELEGRAM_URL=https://t.me/nestera
NEXT_PUBLIC_GITHUB_URL=https://github.com/nestera
NEXT_PUBLIC_SUPPORT_EMAIL=support@nestera.app
NEXT_PUBLIC_LEGAL_EMAIL=legal@nestera.app
BACKEND_API_URL=http://localhost:3001/api/v1
